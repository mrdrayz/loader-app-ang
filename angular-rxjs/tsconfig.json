{
	"compilerOptions": {
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"sourceMap": true,
		"declaration": false,
		"moduleResolution": "Bundler",
		"importHelpers": true,
		"target": "ES2020",
		"module": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"skipLibCheck": true
	},
	"exclude": ["node_modules", "src/**/*.spec.ts", "src/**/*.spec.tsx"],
	"include": ["src/**/*.ts", "src/**/*.d.ts"]
}
